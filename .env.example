# Secrets for the agent container. Copy to .env (gitignored) and fill in.
# If ANTHROPIC_API_KEY is set it is used; otherwise run `agentpod shell` once
# and `claude login` interactively — the login persists via the bind mount.
ANTHROPIC_API_KEY=

# --- Bot git identity ---------------------------------------------------------
# Preferred: register ONCE, shared by all containers:
#   agentpod git-setup --name "agent-bot" --email "bot@users.noreply.github.com" --token <PAT>
# Or override per-project here (applied at container start):
# GIT_BOT_NAME=agent-bot
# GIT_BOT_EMAIL=bot@users.noreply.github.com
# GITHUB_TOKEN=
